---
permalink: /index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "head.njk" %}
</head>
<body>
  <main class="page-wrap">
    <div class="content-col">

      {# ── Profile ──────────────────────────────────────────────────────── #}
      {% include "profile.njk" %}

      {# ── Featured Videos ─────────────────────────────────────────────── #}
      {% if site.featured_videos and site.featured_videos.length %}
      {% for video in site.featured_videos %}
      {% include "featured-video.njk" %}
      {% endfor %}
      {% endif %}

      {# ── Link Sections ───────────────────────────────────────────────── #}
      {% for section in site.sections %}
      <section class="link-section">
        {% include "link-section.njk" %}
      </section>
      {% endfor %}

    </div>
  </main>

  <script src="/assets/lite-youtube.js" defer></script>
</body>
</html>
